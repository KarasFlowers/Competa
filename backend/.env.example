# Competa Backend 环境变量

# 应用
APP_NAME=Competa
DEBUG=true

# 数据库 (MVP 使用 SQLite)
DATABASE_URL=sqlite+aiosqlite:///./competa.db

# LLM 模式: "auto" | "mock" | "real"
#   auto  = 有 API Key 时用真实模型，否则用 Mock
#   mock  = 始终用 Mock（离线演示）
#   real  = 始终用真实模型（无 Key 会报错）
LLM_MODE=auto

# LLM 配置 (支持任何 OpenAI 兼容接口)
# OpenAI:
#   LLM_API_KEY=sk-xxx
#   LLM_BASE_URL=https://api.openai.com/v1
#   LLM_MODEL=gpt-4o
# DeepSeek:
#   LLM_API_KEY=sk-xxx
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
# Moonshot/Kimi:
#   LLM_API_KEY=sk-xxx
#   LLM_BASE_URL=https://api.moonshot.cn/v1
#   LLM_MODEL=moonshot-v1-8k
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=2
